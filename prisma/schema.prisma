generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// End client or prospect (identified by email for this MVP).
model Client {
  id             String          @id @default(cuid())
  email          String          @unique
  creditBalance  Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ledgerEntries  CreditLedger[]
  bookings       Booking[]
}

model CreditLedger {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  @@index([clientId])
}

model Booking {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  /// intro | paid — both consume one credit in MVP; label for your records.
  kind      String   @default("paid")
  status    String   @default("confirmed")
  createdAt DateTime @default(now())

  @@unique([startsAt])
  @@index([clientId])
}
