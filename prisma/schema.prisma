generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// End client or prospect (identified by email for this MVP).
/// Renamed from "Client" to avoid any runtime confusion with PrismaClient / fetch Client.
model BookingAccount {
  id             String          @id @default(cuid())
  email          String          @unique
  creditBalance  Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ledgerEntries  CreditLedger[]
  bookings       Booking[]

  @@map("Client")
}

model CreditLedger {
  id         String         @id @default(cuid())
  clientId   String
  account    BookingAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)
  delta      Int
  reason     String
  createdAt  DateTime       @default(now())

  @@index([clientId])
}

model Booking {
  id        String         @id @default(cuid())
  clientId  String
  account    BookingAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  kind      String         @default("paid")
  status    String         @default("confirmed")
  createdAt DateTime       @default(now())

  @@unique([startsAt])
  @@index([clientId])
}
